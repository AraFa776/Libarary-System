@model List<FirstTry.Models.Book>﻿
<link rel="stylesheet" href="~/css/homeSheet.css" asp-append-version="true" />

@* Start Landing *@
<div class="landing">
	<div class="backge">
		<div class="info">
			<img id="image" src="images/Book.png" alt="Not Found">
			<div class="text">
                <p id="bookTitle">@Model.FirstOrDefault()?.Title</p>
                <p id="bookAuthor">@Model.FirstOrDefault()?.Author?.AuthorsName</p>
                <p id="bookPrice">@Model.FirstOrDefault()?.Price.ToString("C")</p>
				<button>
					More info
				</button>
				<button>
					Buy Now
					<i class="fa-solid fa-cart-shopping active"></i>
				</button>
			</div>
		</div>
		<div class="search">
			<form>
				<i class="fa-solid fa-magnifying-glass"></i>
				<input type="search" placeholder="Search Book...">
				<input type="submit" value="Search">
			</form>
			<div class="photos" id="bookGallery">
				@foreach (var book in Model.Take(6))
				{
					  <div class="image">
                        <img src="~/images/Book.png" alt="@book.Title">
                        <p class="book-title">@book.Title</p>
                        <p class="book-author">@book.Author?.AuthorsName</p>
                        <p class="book-price">@book.Price.ToString("C")</p>
                    </div>
				}
			</div>
		</div>
	</div>
</div>
@* End Landing *@
@* Start Trending *@
<div class="trending">
	<div class="backge">
		<div class="main-heading">
			<span>Trending</span>
			<div class="arrows">
				<button><i class="fa-solid fa-arrow-left"></i></button>
				<button><i class="fa-solid fa-arrow-right"></i></button>
			</div>
		</div>
		<div class="content">
			<div class="text">
				<div class="types">
					<p>Historical Biographies <i class="fa-solid fa-arrow-right"></i></p>
					<p>Leaders & Notable <i class="fa-solid fa-arrow-right"></i></p>
					<p>Modern Biographies <i class="fa-solid fa-arrow-right"></i></p>
					<p>Sports Biographies <i class="fa-solid fa-arrow-right"></i></p>
					<p>United States Biographies <i class="fa-solid fa-arrow-right"></i></p>
					<p>Action & Adventure <i class="fa-solid fa-arrow-right"></i></p>
				</div>
				<button>View More <i class="fa-solid fa-angle-right"></i></button>
			</div>
			<div class="cards">
				@for (int i = 0; i < 3; i++)
				{
					<div class=" card-shape">
						<div class="image">
							<i class="fa-solid fa-heart"></i>
							<img src="images/Book.png" alt="Book">
						</div>
						<div class="info">
							<div class="rate">
								<i class="fa-solid fa-star">  4.5</i>
								<span>140 Reviews</span>
							</div>
							<div class="author">
								<p>By Author Name</p>
								<p>Title of Book</p>
							</div>
							<p><del>Rs 200.00 Eg</del></p>
							<div class="price">
								<span>Rs 100.00 Eg</span>
								<span>50% off</span>
							</div>
							<button> Add To Cart <i class="fa-solid fa-cart-shopping active"></i></button>
						</div>
					</div>
				}
			</div>
		</div>
	</div>
</div>
@* End Trending *@ 
@* Start Arrivals *@
<div class="arrivals">
	<div class="backge">
		<div class="main-heading">
			<span>New Arrivals</span>
			<div class="arrows">
				<button><i class="fa-solid fa-arrow-left"></i></button>
				<button><i class="fa-solid fa-arrow-right"></i></button>
			</div>
		</div>
		<div class="content">
			@for (int i = 0; i < 6; i++)
			{
				<div class=" card-shape">
					<div class="image">
						<i class="fa-solid fa-heart"></i>
						<img src="images/Book.png">
					</div>
					<div class="info">
						<div class="rate">
							<i class="fa-solid fa-star">  4.5</i>
							<span>140 Reviews</span>
						</div>
						<div class="author">
							<p>By Author Name</p>
							<p>Title of Book</p>
						</div>
						<p><del>Rs 200.00 Eg</del></p>
						<div class="price">
							<span>Rs 100.00 Eg</span>
							<span>50% off</span>
						</div>
						<button> Add To Cart <i class="fa-solid fa-cart-shopping active"></i></button>
					</div>
				</div>
			}
		</div>
	</div>
</div>
@* End Arrivals *@
@section Scripts {
    <script>
		            console.log("Start");
        let currentIndex = 0;
        let books = @Html.Raw(Json.Serialize(Model));
		books=books["$values"];
        const bookElements = document.querySelectorAll('#bookGallery .image');

        function rotateBooks() {
            if (books.length === 0) return;
					            console.log("AAAAAA");
            // تحديث الكتاب الرئيس
            const mainBook = books[currentIndex];
            document.getElementById('bookTitle').textContent = mainBook.title;
            document.getElementById('bookAuthor').textContent = mainBook.author.authorsName;
            document.getElementById('bookPrice').textContent = '$' + mainBook.price.toFixed(2);
            
            // تحديث معرض الكتب
            for (let i = 0; i < bookElements.length; i++) {
                const bookIndex = (currentIndex + i + 1) % books.length;
                const book = books[bookIndex];
                
                bookElements[i].querySelector('.book-title').textContent = book.title;
                bookElements[i].querySelector('.book-author').textContent = book.author.authorsName;
                bookElements[i].querySelector('.book-price').textContent = '$' + book.price.toFixed(2);
            }
            
            currentIndex = (currentIndex + 1) % books.length;
        }

        setInterval(rotateBooks, 5000);
        rotateBooks();
    </script>
}
